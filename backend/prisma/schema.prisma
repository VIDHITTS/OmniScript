generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String            @id @default(uuid())
  email              String            @unique
  passwordHash       String?
  fullName           String
  avatarUrl          String?
  authProvider       AuthProvider      @default(LOCAL)
  oauthId            String?
  mfaEnabled         Boolean           @default(false)
  mfaSecret          String?
  emailVerifiedAt    DateTime?
  lastLogin          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  activityLogs       ActivityLog[]
  annotations        Annotation[]
  apiKeys            ApiKey[]
  artifactsGenerated Artifact[]
  auditLogs          AuditLog[]
  chatSessions       ChatSession[]
  documentsUploaded  Document[]
  feedbackMessages   Message[]         @relation("UserFeedback")
  messageFeedbacks   MessageFeedback[]
  refreshTokens      RefreshToken[]
  workspacesOwned    Workspace[]       @relation("OwnerWorkspaces")
  workspaceMembers   WorkspaceMember[]
}

model Workspace {
  id           String            @id @default(uuid())
  name         String
  description  String?
  icon         String?
  ownerId      String
  template     Template          @default(CUSTOM)
  isPublic     Boolean           @default(false)
  settings     Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  activityLogs ActivityLog[]
  annotations  Annotation[]
  artifacts    Artifact[]
  chatSessions ChatSession[]
  documents    Document[]
  kgEntities   KgEntity[]
  owner        User              @relation("OwnerWorkspaces", fields: [ownerId], references: [id])
  members      WorkspaceMember[]
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  joinedAt    DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model ApiKey {
  id          String    @id @default(uuid())
  userId      String
  name        String
  keyHash     String    @unique
  permissions Json?
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Document {
  id               String              @id @default(uuid())
  workspaceId      String
  uploadedById     String
  title            String
  originalFilename String
  storageUrl       String?
  storageBackend   StorageBackend      @default(GRIDFS)
  mimeType         String?
  fileSizeBytes    BigInt?
  sourceType       SourceType
  status           Status              @default(QUEUED)
  errorMessage     String?
  totalChunks      Int                 @default(0)
  tokenCount       Int                 @default(0)
  metadata         Json?
  searchVector     String?
  processedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  uploadedBy       User                @relation(fields: [uploadedById], references: [id])
  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks           DocumentChunk[]
  structures       DocumentStructure[]
}

model DocumentStructure {
  id         String              @id @default(uuid())
  documentId String
  parentId   String?
  title      String
  level      Int
  pageRange  Json?
  sequence   Int
  createdAt  DateTime            @default(now())
  document   Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  parent     DocumentStructure?  @relation("StructureHierarchy", fields: [parentId], references: [id])
  children   DocumentStructure[] @relation("StructureHierarchy")
}

model DocumentChunk {
  id                    String          @id @default(uuid())
  documentId            String
  content               String
  contextualizedContent String?
  embedding             Json?
  chunkIndex            Int
  tokenCount            Int
  sectionHeading        String?
  location              Json?
  searchVector          String?
  rerankScore           Float?
  createdAt             DateTime        @default(now())
  document              Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  kgSourceEdges         KgEdge[]        @relation("SourceChunk")
  kgEntityChunks        KgEntityChunk[]
}

model KgEntity {
  id           String          @id @default(uuid())
  workspaceId  String
  name         String
  entityType   EntityType
  description  String?
  mentionCount Int             @default(0)
  metadata     Json?
  createdAt    DateTime        @default(now())
  sourceEdges  KgEdge[]        @relation("SourceEntity")
  targetEdges  KgEdge[]        @relation("TargetEntity")
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entityChunks KgEntityChunk[]
}

model KgEdge {
  id             String         @id @default(uuid())
  sourceEntityId String
  targetEntityId String
  relationship   String
  confidence     Float
  sourceChunkId  String?
  createdAt      DateTime       @default(now())
  sourceChunk    DocumentChunk? @relation("SourceChunk", fields: [sourceChunkId], references: [id])
  sourceEntity   KgEntity       @relation("SourceEntity", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  targetEntity   KgEntity       @relation("TargetEntity", fields: [targetEntityId], references: [id], onDelete: Cascade)
}

model KgEntityChunk {
  id            String        @id @default(uuid())
  entityId      String
  chunkId       String
  mentionOffset Int?
  chunk         DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  entity        KgEntity      @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, chunkId])
}

model ChatSession {
  id                   String        @id @default(uuid())
  workspaceId          String
  userId               String
  title                String
  parentSessionId      String?
  branchPointMessageId String?
  isPinned             Boolean       @default(false)
  lastActiveAt         DateTime      @default(now())
  createdAt            DateTime      @default(now())
  artifacts            Artifact[]
  parentSession        ChatSession?  @relation("SessionBranches", fields: [parentSessionId], references: [id])
  childSessions        ChatSession[] @relation("SessionBranches")
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace            Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages             Message[]
}

model Message {
  id                 String            @id @default(uuid())
  sessionId          String
  userId             String?
  role               MessageRole
  content            String
  citations          Json?
  toolCalls          Json?
  suggestedFollowups Json?
  tokenUsage         Int?
  confidenceScore    Float?
  isBookmarked       Boolean           @default(false)
  createdAt          DateTime          @default(now())
  annotations        Annotation[]
  session            ChatSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user               User?             @relation("UserFeedback", fields: [userId], references: [id], onDelete: Cascade)
  feedbacks          MessageFeedback[]
}

model MessageFeedback {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  rating    Rating
  comment   String?
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Artifact {
  id              String       @id @default(uuid())
  workspaceId     String
  generatedById   String
  sourceSessionId String?
  artifactType    ArtifactType
  title           String
  content         Json
  exportUrl       String?
  createdAt       DateTime     @default(now())
  generatedBy     User         @relation(fields: [generatedById], references: [id])
  sourceSession   ChatSession? @relation(fields: [sourceSessionId], references: [id])
  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Annotation {
  id              String    @id @default(uuid())
  workspaceId     String
  userId          String
  targetChunkId   String?
  targetMessageId String?
  content         String
  highlightRange  Json?
  createdAt       DateTime  @default(now())
  message         Message?  @relation(fields: [targetMessageId], references: [id])
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String         @id @default(uuid())
  workspaceId String
  userId      String
  action      ActivityAction
  description String
  details     Json?
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  ipAddress String?
  userAgent String?
  action    AuditAction
  details   Json?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

enum Template {
  CUSTOM
  RESEARCH
  COURSE
  LEGAL
  MEETING
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
  COMMENTER
}

enum SourceType {
  PDF
  MARKDOWN
  TEXT
  YOUTUBE
  WEB_URL
  AUDIO
  IMAGE
  CODE
  CSV
}

enum Status {
  QUEUED
  PROCESSING
  CHUNKING
  EMBEDDING
  INDEXED
  FAILED
}

enum EntityType {
  PERSON
  ORG
  CONCEPT
  DATE
  LOCATION
  EVENT
  TERM
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum Rating {
  GOOD
  BAD
  PARTIAL
}

enum ArtifactType {
  SUMMARY
  FLASHCARD_SET
  MIND_MAP
  TIMELINE
  STUDY_GUIDE
  COMPARISON
  GLOSSARY
}

enum ActivityAction {
  UPLOAD
  DELETE
  SHARE
  QUERY
  ANNOTATE
  EXPORT
  SETTINGS_CHANGE
}

enum AuditAction {
  LOGIN
  LOGOUT
  API_CALL
  DATA_EXPORT
  DATA_DELETE
  PERMISSION_CHANGE
}

enum StorageBackend {
  GRIDFS
  S3
}
